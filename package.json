{
  "name": "paperedge",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace @paperedge/dashboard run dev",
    "build": "npm --workspace @paperedge/dashboard run build",
    "build:dashboard": "npm --workspace @paperedge/dashboard run build",
    "start": "npm --workspace @paperedge/dashboard run start",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:seed": "tsx packages/database/prisma/seed.ts",
    "db:backfill-money-cents": "node --import tsx packages/database/prisma/backfill-money-cents.ts",
    "ingest": "tsx scripts/watch-ingest.ts --once",
    "ingest:watch": "tsx scripts/watch-ingest.ts",
    "ingest:pipeline": "tsx scripts/watch-ingest.ts --once --pipeline",
    "edges:fairvalue": "tsx scripts/fair-value-report.ts",
    "edges:arbs": "tsx scripts/arbs-report.ts",
    "detect:edges": "tsx scripts/detect-edges.ts",
    "scan:markets": "tsx scripts/poll-market-scanner.ts --once",
    "scan:markets:watch": "tsx scripts/poll-market-scanner.ts",
    "scan:market-data": "tsx scripts/poll-market-data.ts",
    "scan:market-data:once": "tsx scripts/poll-market-data.ts --config config/paperedge.scanner.config.json --once",
    "scan:summary": "tsx scripts/scan-summary.ts",
    "scan:auto": "tsx scripts/scan-and-pipeline.ts",
    "scan:auto:once": "tsx scripts/scan-and-pipeline.ts --once",
    "dev:dashboard": "npm --workspace @paperedge/dashboard run dev",
    "build:all": "npm run build",
    "typecheck": "tsc --noEmit --pretty false",
    "validate": "npm run typecheck && npm test && npm run build"
  },
  "prisma": {
    "seed": "tsx packages/database/prisma/seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-table": "^8.21.3",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.0",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@rolldown/binding-win32-x64-msvc": "^1.0.2",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4",
    "tsx": "^4.22.2",
    "typescript": "^5",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
