{
  "enabledBooks": [
    "bovada",
    "novig",
    "4c",
    "rebet",
    "prophetx"
  ],
  "sport": "basketball",
  "league": "nba",
  "pollIntervalSeconds": 30,
  "outputDirectories": {
    "rawData": "raw_data",
    "normalizedData": "normalized_data",
    "logs": "logs"
  },
  "books": {
    "bovada": {
      "enabled": true,
      "headers": {
        "accept": "application/json,text/plain,*/*",
        "referer": "https://www.bovada.lv/sports"
      },
      "requests": [
        {
          "id": "bovada-filtered-lines",
          "filePath": "normalized_data/filtered_lines_only.json",
          "sport": "basketball",
          "league": "nba",
          "period": "full_game",
          "live": false
        }
      ]
    },
    "novig": {
      "enabled": true,
      "headers": {
        "accept": "application/json,text/plain,*/*"
      },
      "requests": [
        {
          "id": "novig-filtered-lines",
          "filePath": "normalized_data/filtered_lines_only_novig_latest_2.json",
          "period": "full_game",
          "live": false
        }
      ]
    },
    "4c": {
      "enabled": true,
      "headers": {
        "accept": "application/json,text/plain,*/*",
        "referer": "https://4cx.io/"
      },
      "requests": [
        {
          "id": "4c-nba-orderbook",
          "filePath": "raw_data/4c.json",
          "sport": "basketball",
          "league": "nba",
          "period": "full_game",
          "live": false
        }
      ]
    },
    "rebet": {
      "enabled": true,
      "headers": {
        "accept": "application/json,text/plain,*/*"
      },
      "requests": [
        {
          "id": "rebet-filtered-lines",
          "filePath": "normalized_data/filtered_lines_only_rebet.json",
          "period": "full_game",
          "live": false
        }
      ]
    },
    "prophetx": {
      "enabled": true,
      "headers": {
        "accept": "application/json,text/plain,*/*",
        "referer": "https://www.prophetx.co/"
      },
      "requests": [
        {
          "id": "prophetx-filtered-lines",
          "filePath": "normalized_data/filtered_lines_only_prophetx.json",
          "period": "full_game",
          "live": false
        }
      ]
    }
  }
}
